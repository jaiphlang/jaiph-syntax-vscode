#!/usr/bin/env jaiph

#
# Run from the VS Code extension repo root (git root = plugin source).
# Usage: jaiph path/to/this.jh <branch>
#
# 1. Shallow-clone jaiph (no full history) → tmp/jaiph-<sanitized-branch>
# 2. Prompt: update grammar, syntax, and extension code vs the cloned tree
# 3. Set package.json "version" to match jaiph's package.json
# 4. npm install + npm run package (vsce → .vsix)
#

config {
  agent.backend = "claude"
  agent.claude_flags = "--permission-mode bypassPermissions"
}

script arg_nonempty = `[ -n "${1:-}" ]`

script branch_safe_name = `printf '%s\n' "$1" | tr '/:' '--'`

script clone_jaiph_shallow = ```
  local branch="$1"
  local safe dest
  safe="$(printf '%s\n' "$branch" | tr '/:' '--')"
  dest="tmp/jaiph-$safe"
  rm -rf "$dest"
  mkdir -p tmp
  git clone --depth 1 --branch "$branch" \
    https://github.com/jaiphlang/jaiph.git "$dest" || return 1
  printf '%s\n' "$dest"
```

script sync_plugin_version_from_jaiph_dir = ```
  local jaiph_dir="$1"
  local ver
  ver="$(node -e "console.log(require('./$jaiph_dir/package.json').version)")" || return 1
  node -e "
const fs = require('fs');
const v = process.argv[1];
const p = 'package.json';
const j = JSON.parse(fs.readFileSync(p, 'utf8'));
j.version = v;
fs.writeFileSync(p, JSON.stringify(j, null, 2) + '\n');
  " "$ver" || return 1
  printf '%s\n' "$ver"
```

script pack_extension = ```
  npm install --no-audit --no-fund && npm run package
```

workflow default(branch) {
  if not run arg_nonempty(branch) {
    fail "usage: jaiph <this-file>.jh <branch>"
  }

  const jaiph_dir = run clone_jaiph_shallow(branch)
  const safe_branch = run branch_safe_name(branch)

  prompt """
    ## sasa
    <context>
    1. Read ${jaiph_dir}/docs/grammar.md and scan relevant compiler sources
       under ${jaiph_dir}/src/ if needed for semantics (keywords, constructs).
    2. Update the extension so it stays aligned with the language:
       - syntaxes/jaiph.tmLanguage.json (TextMate grammar)
       - language-configuration.json if needed
       - src/extension.ts (compiler path, diagnostics, activation, etc.)
    3. Keep contributes.languages / grammars / configuration in package.json
       consistent with the above.
    4. Run npm run compile (or your usual compile) and fix issues until the
       extension builds and behaves as you expect.
    5. Assume script code provided in fences by deafult requires shell highlighting
       and when we provide python or python3, then it should use python highlighting,
       for node it's JavaScript highlighting, etc. Fenced prompts should use the
       markdown highlighting. Use Injection Grammars (TextMate) to achieve this.

    Focus on parity with the current Jaiph grammar and compiler behavior for
    this branch.
    </task>
  """

  const new_version = run sync_plugin_version_from_jaiph_dir(jaiph_dir)
  log "package.json version set to ${new_version} (from ${jaiph_dir}/package.json)"

  run pack_extension()
  log "Done. Look for a .vsix in the project root (vsce output)."
}