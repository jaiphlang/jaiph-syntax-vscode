#!/usr/bin/env jaiph

config {
  agent.backend = "claude"
  agent.claude_flags = "--permission-mode bypassPermissions"
}

script branch_safe_name = `printf '%s\n' "$1" | tr '/:' '--'`

script clone_jaiph_shallow = ```
  local branch="$1"
  local safe dest
  safe="$(printf '%s\n' "$branch" | tr '/:' '--')"
  dest="tmp/jaiph-$safe"
  rm -rf "$dest"
  mkdir -p tmp
  git clone --depth 1 --branch "$branch" \
    https://github.com/jaiphlang/jaiph.git "$dest" || return 1
  printf '%s\n' "$dest"
```

script sync_plugin_version_from_jaiph_dir = ```node
  const fs = require('fs');
  const path = require('path');
  
  const jaiphDir = process.argv[2];
  if (!jaiphDir) {
    console.error("Usage: sync_plugin_version_from_jaiph_dir <jaiph_dir>");
    process.exit(1);
  }
  
  const jaiphPkgPath = path.join(jaiphDir, 'package.json');
  let ver;
  try {
    ver = require(path.resolve(jaiphPkgPath)).version;
  } catch (e) {
    console.error(`Failed to read version from ${jaiphPkgPath}: ${e.message}`);
    process.exit(1);
  }
  
  const pkgPath = path.resolve('package.json');
  let pkg;
  try {
    pkg = JSON.parse(fs.readFileSync(pkgPath, 'utf8'));
  } catch (e) {
    console.error(`Failed to read local package.json: ${e.message}`);
    process.exit(1);
  }
  
  pkg.version = ver;
  
  try {
    fs.writeFileSync(pkgPath, JSON.stringify(pkg, null, 2) + '\n');
  } catch (e) {
    console.error(`Failed to write updated package.json: ${e.message}`);
    process.exit(1);
  }
  
  console.log(ver);
```

script pack_extension = ```
  npm install --no-audit --no-fund && npm run package
```

workflow default(branch_param) {
  const safe_branch = match branch_param {
    "" => fail "usage: jaiph <this-file>.jh <branch>"
    _ => run branch_safe_name(branch_param)
  }

  const jaiph_dir = run clone_jaiph_shallow(safe_branch)

  prompt """
    <context>
    1. Read ${jaiph_dir}/docs/grammar.md and scan relevant compiler sources
       under ${jaiph_dir}/src/ if needed for semantics (keywords, constructs).
    2. Update the extension so it stays aligned with the language:
       - syntaxes/jaiph.tmLanguage.json (TextMate grammar)
       - language-configuration.json if needed
       - src/extension.ts (compiler path, diagnostics, activation, etc.)
    3. Keep contributes.languages / grammars / configuration in package.json
       consistent with the above.
    4. Run npm run compile (or your usual compile) and fix issues until the
       extension builds and behaves as you expect.
    5. The extension should highlight compiler errors (compile with jaiph on save)
    6. The extension should allow format command using Jaiph formatter (jaiph format)

    Focus on parity with the current Jaiph grammar and compiler behavior for
    this branch.
    </task>
  """

  const new_version = run sync_plugin_version_from_jaiph_dir(jaiph_dir)
  log "package.json version set to ${new_version} (from ${jaiph_dir}/package.json)"

  run pack_extension()
  log "Done. Look for a .vsix in the project root (vsce output)."
}
