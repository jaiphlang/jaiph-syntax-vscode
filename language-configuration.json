{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"" },
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["\"", "\""],
    ["(", ")"],
    ["[", "]"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(config|rule|workflow|script|test|if|else|match|mock)\\b.*\\{\\s*$|^\\s*(?:(?:export\\s+)?script\\s+[A-Za-z_][A-Za-z0-9_]*\\s*=\\s*|(?:const\\s+[A-Za-z_][A-Za-z0-9_]*\\s*=\\s*)?run\\s+script\\s*\\([^)]*\\)\\s*|prompt\\s+)```\\s*[A-Za-z0-9_]*\\s*$",
      "end": "^\\s*\\}\\s*$|^\\s*```\\s*$"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "\\{\\s*$",
    "decreaseIndentPattern": "^\\s*\\}"
  }
}
