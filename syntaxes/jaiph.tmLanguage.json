{
  "name": "Jaiph",
  "scopeName": "source.jaiph",
  "fileTypes": [
    "jph",
    "jh"
  ],
  "patterns": [
    {
      "include": "#shebang"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#import-statement"
    },
    {
      "include": "#script-block"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#variable-declaration"
    },
    {
      "include": "#channel-declaration"
    },
    {
      "include": "#config-keys"
    },
    {
      "include": "#conditionals"
    },
    {
      "include": "#channels"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#returns-clause"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#references"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "shebang": {
      "patterns": [
        {
          "name": "comment.line.shebang.jaiph",
          "match": "\\A#!.*$"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.jaiph",
          "match": "#.*$"
        }
      ]
    },
    "import-statement": {
      "patterns": [
        {
          "name": "meta.import.jaiph",
          "match": "\\b(import)\\b\\s+(\"(?:\\\\.|[^\"\\\\])*\"|'(?:\\\\.|[^'\\\\])*')\\s+\\b(as)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.control.import.jaiph"
            },
            "2": {
              "name": "string.quoted.jaiph"
            },
            "3": {
              "name": "keyword.control.import.jaiph"
            },
            "4": {
              "name": "entity.name.namespace.jaiph"
            }
          }
        }
      ]
    },
    "script-block": {
      "patterns": [
        {
          "name": "meta.declaration.script.jaiph",
          "begin": "^\\s*\\b(script)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\{)\\s*$",
          "beginCaptures": {
            "1": {
              "name": "storage.type.script.jaiph"
            },
            "2": {
              "name": "entity.name.function.script.jaiph"
            },
            "3": {
              "name": "punctuation.section.block.begin.jaiph"
            }
          },
          "end": "^(\\})",
          "endCaptures": {
            "1": {
              "name": "punctuation.section.block.end.jaiph"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "source.shell"
            }
          ]
        }
      ]
    },
    "config-keys": {
      "patterns": [
        {
          "name": "meta.config.key-value.jaiph",
          "match": "\\b(agent\\.default_model|agent\\.command|agent\\.backend|agent\\.trusted_workspace|agent\\.cursor_flags|agent\\.claude_flags|run\\.logs_dir|run\\.debug|run\\.inbox_parallel|runtime\\.docker_enabled|runtime\\.docker_image|runtime\\.docker_network|runtime\\.docker_timeout|runtime\\.workspace)\\b\\s*(=)",
          "captures": {
            "1": {
              "name": "variable.other.property.jaiph"
            },
            "2": {
              "name": "keyword.operator.assignment.jaiph"
            }
          }
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.jaiph",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.numeric.integer.jaiph",
          "match": "\\b([0-9]+)\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.declaration.config.jaiph",
          "match": "\\b(config)\\b\\s*(\\{)",
          "captures": {
            "1": {
              "name": "storage.type.config.jaiph"
            },
            "2": {
              "name": "punctuation.section.block.begin.jaiph"
            }
          }
        },
        {
          "name": "meta.declaration.rule.jaiph",
          "match": "\\b(export)\\b\\s+\\b(rule)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\{)",
          "captures": {
            "1": {
              "name": "storage.modifier.jaiph"
            },
            "2": {
              "name": "storage.type.rule.jaiph"
            },
            "3": {
              "name": "entity.name.function.rule.jaiph"
            },
            "4": {
              "name": "punctuation.section.block.begin.jaiph"
            }
          }
        },
        {
          "name": "meta.declaration.workflow.jaiph",
          "match": "\\b(export)\\b\\s+\\b(workflow)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\{)",
          "captures": {
            "1": {
              "name": "storage.modifier.jaiph"
            },
            "2": {
              "name": "storage.type.workflow.jaiph"
            },
            "3": {
              "name": "entity.name.function.workflow.jaiph"
            },
            "4": {
              "name": "punctuation.section.block.begin.jaiph"
            }
          }
        },
        {
          "name": "meta.declaration.rule.jaiph",
          "match": "\\b(rule)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\{)",
          "captures": {
            "1": {
              "name": "storage.type.rule.jaiph"
            },
            "2": {
              "name": "entity.name.function.rule.jaiph"
            },
            "3": {
              "name": "punctuation.section.block.begin.jaiph"
            }
          }
        },
        {
          "name": "meta.declaration.workflow.jaiph",
          "match": "\\b(workflow)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\{)",
          "captures": {
            "1": {
              "name": "storage.type.workflow.jaiph"
            },
            "2": {
              "name": "entity.name.function.workflow.jaiph"
            },
            "3": {
              "name": "punctuation.section.block.begin.jaiph"
            }
          }
        },
        {
          "name": "meta.declaration.test.jaiph",
          "match": "\\b(test)\\b\\s+(\"(?:\\\\.|[^\"\\\\])*\")\\s*(\\{)",
          "captures": {
            "1": {
              "name": "storage.type.test.jaiph"
            },
            "2": {
              "name": "string.quoted.double.jaiph"
            },
            "3": {
              "name": "punctuation.section.block.begin.jaiph"
            }
          }
        }
      ]
    },
    "variable-declaration": {
      "patterns": [
        {
          "name": "meta.variable.jaiph",
          "match": "\\b(const)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(=)",
          "captures": {
            "1": {
              "name": "storage.modifier.jaiph"
            },
            "2": {
              "name": "variable.other.jaiph"
            },
            "3": {
              "name": "keyword.operator.assignment.jaiph"
            }
          }
        }
      ]
    },
    "channel-declaration": {
      "patterns": [
        {
          "name": "meta.channel.declaration.jaiph",
          "match": "^\\s*\\b(channel)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*$",
          "captures": {
            "1": {
              "name": "storage.type.channel.jaiph"
            },
            "2": {
              "name": "variable.other.channel.jaiph"
            }
          }
        }
      ]
    },
    "conditionals": {
      "patterns": [
        {
          "name": "keyword.control.conditional.jaiph",
          "match": "\\b(if|else\\s+if|else|not)\\b"
        },
        {
          "comment": "bash-style conditionals used in test mock blocks",
          "name": "keyword.control.conditional.jaiph",
          "match": "\\b(then|elif|fi)\\b"
        }
      ]
    },
    "channels": {
      "patterns": [
        {
          "comment": "inbox forward: inbox <- (sends ${arg1})",
          "name": "meta.send.inbox.jaiph",
          "match": "^\\s*\\b(inbox)\\b\\s*(<-)",
          "captures": {
            "1": {
              "name": "keyword.control.inbox.jaiph"
            },
            "2": {
              "name": "keyword.operator.send.jaiph"
            }
          }
        },
        {
          "name": "meta.send.jaiph",
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(<-)",
          "captures": {
            "1": {
              "name": "variable.other.channel.jaiph"
            },
            "2": {
              "name": "keyword.operator.send.jaiph"
            }
          }
        },
        {
          "name": "meta.route.jaiph",
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(->)\\s+(.+)$",
          "captures": {
            "1": {
              "name": "variable.other.channel.jaiph"
            },
            "2": {
              "name": "keyword.operator.route.jaiph"
            },
            "3": {
              "name": "entity.name.function.workflow.jaiph"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.command.jaiph",
          "match": "\\b(ensure|run|prompt|log|logerr|recover|fail|return|wait)\\b"
        },
        {
          "name": "keyword.control.async.jaiph",
          "match": "\\b(run)\\b\\s+\\b(async)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.command.jaiph"
            },
            "2": {
              "name": "keyword.control.async.jaiph"
            }
          }
        },
        {
          "name": "keyword.control.test.jaiph",
          "match": "\\b(mock|respond|contains|allow_failure)\\b"
        },
        {
          "name": "keyword.other.assertion.jaiph",
          "match": "\\b(expectContain|expectNotContain|expectEqual)\\b"
        },
        {
          "name": "storage.modifier.jaiph",
          "match": "\\b(export)\\b"
        }
      ]
    },
    "returns-clause": {
      "patterns": [
        {
          "name": "meta.returns.jaiph",
          "match": "\\b(returns)\\b\\s*('(?:\\\\.|[^'\\\\])*'|\"(?:\\\\.|[^\"\\\\])*\")",
          "captures": {
            "1": {
              "name": "keyword.control.returns.jaiph"
            },
            "2": {
              "name": "string.quoted.schema.jaiph"
            }
          }
        }
      ]
    },
    "references": {
      "patterns": [
        {
          "name": "meta.reference.qualified.jaiph",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(\\.)([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "entity.name.namespace.jaiph"
            },
            "2": {
              "name": "punctuation.accessor.dot.jaiph"
            },
            "3": {
              "name": "variable.other.member.jaiph"
            }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.jaiph",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.jaiph"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.jaiph"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.jaiph",
              "match": "\\\\."
            },
            {
              "comment": "Inline capture interpolation: ${run ref()} or ${ensure ref()}",
              "name": "meta.interpolation.capture.jaiph",
              "match": "(\\$\\{)\\s*(run|ensure)\\s+([A-Za-z_][A-Za-z0-9_.]*\\([^)]*\\))\\s*(\\})",
              "captures": {
                "1": {
                  "name": "punctuation.definition.interpolation.begin.jaiph"
                },
                "2": {
                  "name": "keyword.control.command.jaiph"
                },
                "3": {
                  "name": "entity.name.function.jaiph"
                },
                "4": {
                  "name": "punctuation.definition.interpolation.end.jaiph"
                }
              }
            },
            {
              "comment": "Variable interpolation: ${varName}",
              "name": "meta.interpolation.variable.jaiph",
              "match": "(\\$\\{)([A-Za-z_][A-Za-z0-9_]*)(\\})",
              "captures": {
                "1": {
                  "name": "punctuation.definition.interpolation.begin.jaiph"
                },
                "2": {
                  "name": "variable.other.interpolated.jaiph"
                },
                "3": {
                  "name": "punctuation.definition.interpolation.end.jaiph"
                }
              }
            }
          ]
        },
        {
          "name": "string.quoted.single.jaiph",
          "begin": "'",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.jaiph"
            }
          },
          "end": "'",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.jaiph"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.jaiph",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.jaiph",
          "match": "(?<![<>!])=(?!=)"
        },
        {
          "name": "punctuation.terminator.statement.jaiph",
          "match": ";"
        },
        {
          "name": "punctuation.section.block.begin.jaiph",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.jaiph",
          "match": "\\}"
        }
      ]
    }
  }
}